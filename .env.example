# Supabase configuration
# Copy this file to .env.local and fill in your project keys from https://app.supabase.io
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Admin panel auth (the admin user must be created in Supabase Auth)
# You can leave these empty if you only create the user via Supabase dashboard.
# Local dev convenience only.
VITE_ADMIN_EMAIL=
VITE_ADMIN_PASSWORD=
